schema {
    query: Query
}

type Query {
    settings: ServerSettings
    myself: GraphQlUser
}

type ServerSettings {
    telegram: Boolean # Telegram features flag
    bot: Boolean # Bot features flag
}

type GraphQlUser {
    id: ID!

    username: String
    nickname: String!
    bio: String

    registerTime: Date!
    lastLoginTime: Date

    status: GraphQlStatus
}

scalar Date
@specifiedBy(url:
"https://tools.ietf.org/html/rfc3339"
)

type GraphQlStatus {
    text: String
}