type Query {
    settings: ServerSettings
    myself: User
}

type ServerSettings {
    telegram: Boolean # Telegram features flag
    bot: Boolean # Bot features flag
}

type User {
    id: ID

    username: String
    nickname: String
    bio: String

    registerTime: Date
    lastLoginTime: Date

    status: Status
}

scalar Date
@specifiedBy(url:
"https://tools.ietf.org/html/rfc3339"
)

type Status {
    text: String
}